theorem saveRa_signs_abs_signXor_then_divCall_bzero_then_return_normalized_from_handoff_spec_in_sdivCodeV4
    (vRa vSavedOld sp sDividendOld sDivisorOld
      dividendMaskOld dividendValueOld dividendCarryOld
